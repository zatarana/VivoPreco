    <string name="onboarding_title_1">Bem-vindo ao seu centro pessoal</string>
    <string name="onboarding_body_1">O LifeFlow Pro reúne tarefas, finanças e dívidas em um único app offline-first, pensado para uso diário e rápido.</string>
